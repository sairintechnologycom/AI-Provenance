datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model Organization {
  id           String       @id @default(cuid())
  githubId     String       @unique
  login        String
  repositories Repository[]
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id])
  workspaceId  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Workspace {
  id               String         @id @default(cuid())
  name             String
  slackWebhookUrl  String?
  organizations    Organization[]
  users            User[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("MEMBER") // ADMIN, MEMBER
  accounts      Account[]
  sessions      Session[]
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  workspaceId   String?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  email        String
  company      String
  role         String
  teamSize     String
  interest     String?
  source       String?
  createdAt    DateTime @default(now())
}

model AppEvent {
  id        String   @id @default(cuid())
  event     String
  payload   Json?
  createdAt DateTime @default(now())
}

model Repository {
  id             String        @id @default(cuid())
  githubId       String        @unique
  owner          String
  name           String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  pullRequests   PullRequest[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([owner, name])
}

model PullRequest {
  id           String     @id @default(cuid())
  githubId     String     @unique
  number       Int
  repository   Repository @relation(fields: [repositoryId], references: [id])
  repositoryId String

  // Review Status
  status       String  @default("PENDING") // PENDING, APPROVED, REJECTED
  approvalNote String?
  merged       Boolean @default(false)

  reviewEvents ReviewEvent[]
  packet       MergeBriefPacket?
  analysisJobs AnalysisJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repositoryId, number])
}

model ReviewEvent {
  id            String      @id @default(cuid())
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  pullRequestId String
  eventType     String // APPROVAL, REJECTION, COMMENT
  username      String // GitHub username
  note          String
  createdAt     DateTime    @default(now())
}

model MergeBriefPacket {
  id            String      @id @default(cuid())
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  pullRequestId String      @unique

  status  String @default("QUEUED") // QUEUED, PROCESSING, COMPLETED, FAILED
  version Int    @default(1)

  headSha String?
  baseSha String?

  // Overarching stats
  summary           String?
  aiTool            String?
  confidence        Int?
  filesChangedCount Int?

  rawPayload String? // JSON context

  tags                PacketRiskTag[]
  intents             PacketIntent[]
  reviewerSuggestions PacketReviewerSuggestion[]
  provenanceEvidence  PacketProvenanceEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slackSentAt DateTime?
}

model PacketRiskTag {
  id       String           @id @default(cuid())
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  packetId String

  type     String // "DETERMINISTIC" or "INFERRED"
  category String // e.g. "auth", "infra"
  reason   String?
}

model PacketIntent {
  id       String           @id @default(cuid())
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  packetId String

  detail String // E.g. "Refactoring auth module"
}

model PacketReviewerSuggestion {
  id       String           @id @default(cuid())
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  packetId String

  username String
  reason   String? // Based on which files or CODEOWNERS rules
}

model PacketProvenanceEvidence {
  id       String           @id @default(cuid())
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  packetId String

  file       String?
  method     String // e.g., "trailer", "heuristic"
  confidence Int?
}

model AnalysisJob {
  id            String      @id @default(cuid())
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  pullRequestId String

  status      String  @default("QUEUED") // QUEUED, PROCESSING, COMPLETED, FAILED
  errorDetail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
