generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String       @id @default(cuid())
  githubId     String       @unique
  login        String
  workspaceId  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id])
  repositories Repository[]
}

model Workspace {
  id              String         @id @default(cuid())
  name            String
  slackWebhookUrl String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  organizations   Organization[]
  users           User[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          String     @default("MEMBER")
  workspaceId   String?
  accounts      Account[]
  sessions      Session[]
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  role      String
  teamSize  String
  interest  String?
  source    String?
  createdAt DateTime @default(now())
}

model AppEvent {
  id        String   @id @default(cuid())
  event     String
  payload   Json?
  createdAt DateTime @default(now())
}

model Repository {
  id             String        @id @default(cuid())
  githubId       String        @unique
  owner          String
  name           String
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  pullRequests   PullRequest[]
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@unique([owner, name])
}

model PullRequest {
  id           String            @id @default(cuid())
  githubId     String            @unique
  number       Int
  repositoryId String
  status       String            @default("PENDING")
  approvalNote String?
  merged       Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  analysisJobs AnalysisJob[]
  packet       MergeBriefPacket?
  repository   Repository        @relation(fields: [repositoryId], references: [id])
  reviewEvents ReviewEvent[]

  @@unique([repositoryId, number])
}

model ReviewEvent {
  id            String      @id @default(cuid())
  pullRequestId String
  eventType     String
  username      String
  note          String
  createdAt     DateTime    @default(now())
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
}

model MergeBriefPacket {
  id                  String                     @id @default(cuid())
  pullRequestId       String                     @unique
  status              String                     @default("QUEUED")
  version             Int                        @default(1)
  headSha             String?
  baseSha             String?
  summary             String?
  aiTool              String?
  confidence          Int?
  filesChangedCount   Int?
  rawPayload          String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  slackSentAt         DateTime?
  pullRequest         PullRequest                @relation(fields: [pullRequestId], references: [id])
  intents             PacketIntent[]
  provenanceEvidence  PacketProvenanceEvidence[]
  reviewerSuggestions PacketReviewerSuggestion[]
  tags                PacketRiskTag[]
}

model PacketRiskTag {
  id       String           @id @default(cuid())
  packetId String
  type     String
  category String
  reason   String?
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model PacketIntent {
  id       String           @id @default(cuid())
  packetId String
  detail   String
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model PacketReviewerSuggestion {
  id       String           @id @default(cuid())
  packetId String
  username String
  reason   String?
  packet   MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model PacketProvenanceEvidence {
  id         String           @id @default(cuid())
  packetId   String
  file       String?
  method     String
  confidence Int?
  packet     MergeBriefPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
}

model AnalysisJob {
  id            String      @id @default(cuid())
  pullRequestId String
  packetId      String?
  checkRunId    String?
  status        String      @default("QUEUED")
  payload       Json?
  errorDetail   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
}
