# GitHub App Credentials
APP_ID=
PRIVATE_KEY=
WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=              # From Slack App > Basic Information > Signing Secret

# Server Configuration
PORT=3000
LOG_LEVEL=info

# AI Provenance Settings
