NEXTAUTH_URL=http://localhost:3001
GITHUB_ID=                        # From GitHub App settings
GITHUB_SECRET=                    # From GitHub App settings
BASE_UI_URL=http://localhost:3001

# --- Monetization (Polar.sh) ---
POLAR_ORGANIZATION_ID=             # Your Polar Organization ID
MERGEBRIEF_LICENSE=                # For local CLI development/testing
